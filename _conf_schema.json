{
  "debug_mode": {
    "type": "bool",
    "description": "开启调试日志",
    "default": false
  },
  "tasks": {
    "type": "template_list",
    "description": "定时任务",
    "templates": {
      "default": {
        "name": "新任务",
        "items": {
          "time": {
            "type": "string",
            "description": "触发时间 (HH:MM)",
            "default": "09:00"
          },
          "umo": {
            "type": "string",
            "description": "目标UMO（格式：Bot名称:消息类型:会话ID）",
            "default": ""
          },
          "at_all": {
            "type": "bool",
            "description": "是否@全体成员",
            "default": false
          }
        }
      }
    },
    "default": []
  }
}
